{# templates/router_main.json.j2 #}
{
  "log": {
    "disabled": false,
    "level": "warn",
    "output": "{{ router.log_path }}",
    "timestamp": true
  },
  "dns": {
    "strategy": "prefer_ipv6",
    "servers": [
      { "tag": "cloudflare", "type": "https", "server": "1.1.1.1" },
      { "tag": "google", "type": "https", "server": "8.8.8.8" },
      { "tag": "yandex", "type": "https",  "server": "77.88.8.8" },
      { "tag": "local", "type": "local" }
    ],
    "rules": [
      { "domain_suffix": [".local", ".lan"], "server": "local" },
      { "domain_suffix": "proton.me", "server": "google", "strategy": "ipv4_only" },
      { "rule_set": "category-ads-all", "action": "reject" },
      { "rule_set": ["router", "openai", "youtube", "telegram", "reddit"], "server": "cloudflare", "strategy": "ipv4_only" },
      { "rule_set": ["category-ru", "category-ir", "geosite-cn"], "server": "yandex" }
    ]
  },
  "inbounds": [
    {
      "type": "tproxy",
      "tag": "tproxy-ipv4",
      "listen": "127.0.0.1",
      "listen_port": {{ router.tproxy.ipv4_port }}
    },
    {
      "type": "tproxy",
      "tag": "tproxy-ipv6",
      "listen": "::1",
      "listen_port": {{ router.tproxy.ipv6_port }}
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct",
      "routing_mark": {{ router.routing_mark }}
    },
{% set balancers = [
    ('naive-balancer', 'naive')
] %}
{% for balancer_tag, outbound_prefix in balancers %}
    {
      "type": "urltest",
      "tag": "{{ balancer_tag }}",
      "outbounds": [
{% set target = relay_instances if relay_instances else instances %}
{% for name, _ in target.items() %}
        "{{ outbound_prefix }}-{{ loop.index }}"{{ "," if not loop.last else "" }}
{% endfor %}
      ]
    }{{ "," if not loop.last else "" }}
{% endfor %}
  ],
  "route": {
    "default_domain_resolver": "cloudflare",
    "rule_set": [
      {
        "type": "remote",
        "tag": "router",
        "format": "binary",
        "update_interval": "10m",
        "url": "{{ srs.router.link }}"
      },
{% set static_rules = [
    ('openai', 'https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-openai.srs'),
    ('category-ru', 'https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-category-ru.srs'),
    ('category-ir', 'https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-category-ir.srs'),
    ('telegram', 'https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-telegram.srs'),
    ('youtube', 'https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-youtube.srs'),
    ('category-ads-all', 'https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-category-ads-all.srs'),
    ('reddit', 'https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-reddit.srs')
] %}
{% for tag, url in static_rules %}
      {
        "type": "remote",
        "tag": "{{ tag }}",
        "format": "binary",
        "update_interval": "1h",
        "url": "{{ url }}"
      }{{ "," if not loop.last else "" }}
{% endfor %}
    ],
    "rules": [
      {"action": "sniff"},
      {"protocol": "dns", "action": "hijack-dns"},
      {"port": [123], "outbound": "direct"},
      {"rule_set": "category-ads-all", "action": "reject"},
      {"rule_set": ["router", "openai", "youtube", "telegram", "reddit"], "outbound": "naive-balancer"}
    ]
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "cache_id": "{{ router.cache_id }}",
      "path": "{{ router.cache_path }}"
    }
  }
}
